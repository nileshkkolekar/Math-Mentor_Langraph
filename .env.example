# OpenAI (for agents)
OPENAI_API_KEY=

# Model names
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_VERIFIER=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o-mini

# RAG
RAG_TOP_K=5
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Chroma Cloud (optional – use for Streamlit Cloud so vector store persists)
# Get API key, tenant, database at https://www.trychroma.com/
# When set, RAG uses Chroma Cloud instead of local data/chroma
# CHROMA_API_KEY=
# CHROMA_TENANT=default_tenant
# CHROMA_DATABASE=default_database

# Paths
KNOWLEDGE_BASE_DIR=./knowledge_base
MEMORY_DB_PATH=./data/memory.db

# HITL thresholds (0.0 to 1.0)
OCR_CONFIDENCE_THRESHOLD=0.7
VERIFIER_CONFIDENCE_THRESHOLD=0.75
